{
  "name": "chrome-extension-upload",
  "version": "4.0.1",
  "private": true,
  "description": "upload & publish extensions to the Chrome Web Store",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc",
    "format": "prettier --write **/*.ts",
    "format-check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts",
    "pack": "ncc build",
    "test": "jest",
    "all": "npm run build && npm run format && npm run lint && npm run pack"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mnao305/chrome-extension-upload.git"
  },
  "keywords": [
    "actions",
    "node",
    "setup"
  ],
  "author": "mnao305",
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "axios": "^1.7.9",
    "chrome-webstore-upload": "^4.0.0",
    "glob": "^7.2.3"
  },
  "devDependencies": {
    "@babel/core": "^7.26.0",
    "@babel/preset-env": "^7.26.0",
    "@types/glob": "^7.2.0",
    "@types/jest": "^27.5.2",
    "@types/node": "^16.0.0",
    "@typescript-eslint/eslint-plugin": "^5.62.0",
    "@typescript-eslint/parser": "^5.62.0",
    "@vercel/ncc": "^0.36.1",
    "babel-jest": "^27.3.1",
    "eslint": "^8.57.1",
    "eslint-plugin-github": "^4.10.2",
    "eslint-plugin-jest": "^22.21.0",
    "jest": "^27.5.1",
    "jest-circus": "^27.5.1",
    "js-yaml": "^3.14.1",
    "prettier": "^1.19.1",
    "ts-jest": "^27.1.5",
    "typescript": "^4.9.5"
  }
}
